{
    // Editor settings
    "editor.fontFamily": "JetBrainsMonoNL Nerd Font",
    "editor.fontSize": 14,
    "editor.lineNumbers": "relative",
    "editor.minimap.enabled": false,
    "editor.smoothScrolling": true,
    "editor.inlineSuggest.enabled": false,

    // Extension settings
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "find-it-faster.general.killTerminalAfterUse": true,
    "json.schemas": [],
    "redhat.telemetry.enabled": false,

    // UI settings
    "window.zoomLevel": 2,
    "workbench.colorTheme": "IntelliJ-ish Darcula",
    "workbench.editor.showTabs": "none",
    "window.menuBarVisibility": "hidden",

    // YAML settings
    "yaml.schemas": {
        "/home/sabah/yaml_schemas/scrape.json": ["scrape*.yml"]
    },

    // Terminal settings
    "terminal.integrated.profiles.linux": {
        "tmux-shell": {
            "path": "tmux",
            "args": ["new-session", "-A", "-s", "VS:${workspaceFolderBasename}"]
        }
    },
    "terminal.integrated.defaultProfile.linux": "tmux-shell",

    // Python testing settings
    "python.testing.pytestArgs": [".", "--continue-on-collection-errors"],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,

    // Notebook settings
    "notebook.cellToolbarLocation": {
        "default": "right"
    }
}