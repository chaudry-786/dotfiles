[
    // General
    {
        "key": "ctrl+o",
        "command": "workbench.action.navigateBack"
    },
    {
        "key": "ctrl+i",
        "command": "workbench.action.navigateForward"
    },
    {
        "key": "ctrl+q",
        "command": "workbench.action.closeActiveEditor",
        "when": "!isInDiffEditor"
    },
    {
        "key": "ctrl+q",
        "command": "git.closeAllDiffEditors",
        "when": "isInDiffEditor"
    },
    {
        "key": "ctrl+shift+q",
        "command": "workbench.action.editorLayoutSingle"
    },
    {
        "key": "alt+o",
        "command": "workbench.action.openRecent"
    },
    {
        "key": "alt+shift+o",
        "command": "workbench.action.files.openFolder",
        "when": "openFolderWorkspaceSupport"
    },
    // Redo
    {
        "command": "vscode-neovim.send",
        "key": "ctrl+r",
        "args": "<C-r>"
    },
    //
    // Tree explorer toggle
    {
        "key": "alt+n",
        "command": "workbench.view.explorer",
        "when": "!explorerViewletVisible"
    },
    {
        "key": "alt+n",
        "command": "workbench.action.closeSidebar",
        "when": "explorerViewletVisible"
    },
    {
        "key": "y",
        "command": "copyRelativeFilePath",
        "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    // Scroll fix
    {
        "command": "vscode-neovim.send",
        "key": "ctrl+d",
        "args": "<C-d>jk"
    },
    {
        "command": "vscode-neovim.send",
        "key": "ctrl+u",
        "args": "<C-u>jk"
    },
    //
    // Search explorer
    {
        "key": "enter",
        "command": "search.action.focusSearchList",
        "when": "activeViewlet == 'workbench.view.search' && inputFocus"
    },
    {
        "key": "/",
        "command": "workbench.action.findInFiles",
        "when": "activeViewlet == 'workbench.view.search' && !inputFocus"
    },
    //
    // Navigation between windows
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusPreviousGroup",
        "when": "neovim.mode != 'insert'"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.navigateDown",
        "when": "( terminalFocus || editorTextFocus  ) && neovim.mode != 'insert' && !panelMaximized"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.navigateUp",
        "when": "neovim.mode != 'insert' && !panelMaximized"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u000b" },
        "when": "panelMaximized"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusNextGroup",
        "when": "neovim.mode != 'insert'"
    },
    // Snippet
    {
        "key": "ctrl+l",
        "command": "vscode-neovim.send",
        "when": "neovim.mode == 'insert'",
        "args": "<C-l>"
    },
    {
        "key": "ctrl+j",
        "command": "jumpToNextSnippetPlaceholder",
        "when": "editorTextFocus && neovim.mode == 'insert' && inSnippetMode"
    },
    {
        "key": "ctrl+k",
        "command": "jumpToPrevSnippetPlaceholder",
        "when": "neovim.mode == 'insert' && inSnippetMode"
    },
    //
    // Auto-compeletion navigation
    {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "editorTextFocus && suggestWidgetVisible && neovim.mode == 'insert' && !inSnippetMode"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "neovim.mode == 'insert' && !inSnippetMode"
    },
    //
    // Quick-open navigation and escape
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenNavigatePrevious",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenNavigateNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+[",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "inQuickOpen && !editorReadonly"
    },
    {
        "key": "ctrl+[",
        "command": "type",
        "args": {
            "text": "\u001b"
        },
        "when": "neovim.init && neovim.mode == 'cmdline'"
    },
    //
    // Resize windows
    {
        "key": "alt+j",
        "command": "workbench.action.increaseViewSize",
        "when": "activeEditorGroupIndex != lastEditorGroupIndex"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.decreaseViewSize",
        "when": "activeEditorGroupIndex != 0"
    },
    {
        "key": "alt+j",
        "command": "workbench.action.terminal.resizePaneDown"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.terminal.resizePaneUp"
    },
    //
    // Terminal toggle
    {
        "key": "alt+t",
        "command": "workbench.action.closePanel",
        "when": "terminalFocus"
    },
    {
        "key": "alt+t",
        "command": "workbench.action.terminal.focus",
        "when": "!terminalFocus"
    },
    {
        "key": "alt+shift+t",
        "command": "workbench.action.toggleMaximizedPanel"
    },
    //
    // Debug Console toggle
    {
        "key": "alt+d",
        "command": "workbench.debug.action.toggleRepl",
        "when": "!debugConsoleVisible"
    },
    {
        "key": "alt+d",
        "command": "workbench.action.closePanel",
        "when": "debugConsoleVisible"
    },
    {
        "key": "alt+shift+d",
        "command": "workbench.view.debug",
        "when": "!view.workbench.debug.variablesView.visible"
    },
    {
        "key": "alt+shift+d",
        "command": "workbench.action.closeSidebar",
        "when": "view.workbench.debug.variablesView.visible"
    },
    // Problems panel toggle
    {
        "key": "alt+p",
        "command": "workbench.actions.view.problems",
        "when": "!problemsViewVisible"
    },
    {
        "key": "alt+p",
        "command": "workbench.action.closePanel",
        "when": "problemsViewVisible"
    },
    // Search side window toggle
    {
        "key": "alt+f",
        "command": "workbench.view.search",
        "when": "!searchViewletVisible"
    },
    {
        "key": "alt+f",
        "command": "workbench.action.closeSidebar",
        "when": "searchViewletVisible"
    },
    // Git  window toggle
    {
        "key": "alt+g",
        "command": "workbench.view.scm",
        "when": "activeViewlet != 'workbench.view.scm'"
    },
    {
        "key": "alt+g",
        "command": "workbench.action.closeSidebar",
        "when": "activeViewlet == 'workbench.view.scm'"
    },
    //
    // Activity bar toggle
    {
        "key": "alt+a",
        "command": "workbench.action.toggleActivityBarVisibility"
    },
    //
    // Notebook
    {
        "key": "o",
        "command": "notebook.cell.insertCodeCellBelowAndFocusContainer",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "shift+O",
        "command": "notebook.cell.insertCodeCellAboveAndFocusContainer",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "] c",
        "command": "notebook.focusNextEditor",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "[ c",
        "command": "notebook.focusPreviousEditor",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "] shift+c",
        "command": "notebook.focusBottom",
        "when": "notebookEditorFocused && !inputFocus"
    },
    {
        "key": "ctrl+enter",
        "command": "notebook.cell.execute",
        "when": "notebookCellListFocused || editorTextFocus && inputFocus && notebookEditorFocused"
    },
    //
    // Github copilot
    {
        "key": "alt+i",
        "command": "inlineChat.start"
    },
    {
        "key": "alt+c",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "activeAuxiliary"
    },
    {
        "key": "alt+c",
        "command": "workbench.action.chat.openInSidebar",
        "when": "!auxiliaryBarFocus || !activeAuxiliary"
    },
    {
        "key": "alt+shift+c",
        "command": "workbench.action.chat.openInEditor"
    },
    {
        "key": "alt+enter",
        "command": "inlineChat.acceptChanges",
        "when": "inlineChatHasProvider && inlineChatVisible && !inlineChatDocumentChanged || inlineChatHasProvider && inlineChatVisible && config.inlineChat.mode != 'preview'"
    },
    //
    // Tests
    {
        "key": "alt+r",
        "command": "testing.refreshTests"
    },
    // Removed default mappings
    {
        "key": "ctrl+f",
        "command": "-workbench.action.terminal.focusFind",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },
    {
        "key": "ctrl+g",
        "command": "-workbench.action.terminal.goToRecentDirectory",
        "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
    },
    {
        "key": "ctrl+f",
        "command": "-actions.find",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "ctrl+v",
        "command": "-workbench.action.terminal.paste",
        "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
    },
    {
        "key": "ctrl+enter",
        "command": "-inlineChat.acceptChanges",
        "when": "inlineChatHasProvider && inlineChatVisible && !inlineChatDocumentChanged || inlineChatHasProvider && inlineChatVisible && config.inlineChat.mode != 'preview'"
    },
    {
        "key": "ctrl+shift+v",
        "command": "-markdown.showPreview",
        "when": "!notebookEditorFocused && editorLangId == 'markdown'"
    },
    {
        "key": "ctrl+enter",
        "command": "-notebook.cell.executeAndFocusContainer",
        "when": "notebookCellListFocused || editorTextFocus && inputFocus && notebookEditorFocused"
    },
    {
        "key": "ctrl+g",
        "command": "-workbench.action.gotoLine"
    },
    {
        "key": "ctrl+enter",
        "command": "-github.copilot.generate",
        "when": "editorTextFocus && github.copilot.activated && !commentEditorFocused && !inInteractiveInput && !interactiveEditorFocused"
    },
    {
        "key": "ctrl+e",
        "command": "-workbench.action.quickOpen"
    },
    // scroll fix (delete default mappings)
    {
        "command": "-vscode-neovim.send",
        "key": "ctrl+d"
    },
    {
        "command": "-vscode-neovim.send",
        "key": "ctrl+u"
    },

    {
        "key": "ctrl+r",
        "command": "-workbench.action.openRecent"
    },
    {
        "key": "ctrl+j",
        "command": "-vscode-neovim.send-cmdline",
        "when": "neovim.init && neovim.mode == 'cmdline'"
    },
    {
        "key": "ctrl+j",
        "command": "-vscode-neovim.send",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.j && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+j",
        "command": "-vscode-neovim.send",
        "when": "editorTextFocus && neovim.ctrlKeysInsert.j && neovim.init && neovim.mode == 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+j",
        "command": "-workbench.action.togglePanel"
    }
]
