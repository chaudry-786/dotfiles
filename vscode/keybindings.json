[
    {
        "key": "ctrl+n",
        "command": "workbench.view.explorer",
        "when": "!explorerViewletVisible"
    },
    {
        "key": "ctrl+n",
        "command": "workbench.action.closeSidebar",
        "when": "explorerViewletVisible"
    },
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusPreviousGroup",
        "when": "neovim.mode != 'insert'"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusNextGroup",
        "when": "neovim.mode != 'insert'"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.navigateUp",
        "when": "neovim.mode != 'insert'"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "neovim.mode == 'insert'"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenNavigatePrevious",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.navigateDown",
        "when": "neovim.mode != 'insert'"
    },
    {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "neovim.mode == 'insert'"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenNavigateNext",
        "when": "inQuickOpen"
    },
    {
        "key": "o",
        "command": "notebook.cell.insertCodeCellBelowAndFocusContainer",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "shift+O",
        "command": "notebook.cell.insertCodeCellAboveAndFocusContainer",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "ctrl+[",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "inQuickOpen && !editorReadonly"
    },
    {
        "key": "ctrl+shift+t",
        "command": "workbench.action.togglePanel",
        "when": "!panelVisible || terminalFocus"
    },
    {
        "key": "ctrl+shift+t",
        "command": "workbench.action.terminal.focus",
        "when": "panelVisible && !terminalFocus"
    },
    {
        "key": "ctrl+o",
        "command": "workbench.action.navigateBack"
    },
    {
        "key": "ctrl+i",
        "command": "workbench.action.navigateForward"
    },
    {
        "key": "ctrl+q",
        "command": "workbench.action.closeActiveEditor"
    },
    {
        "key": "ctrl+alt+i",
        "command": "inlineChat.start"
    },
    // {
    //     "key": "ctrl+alt+shift+c",
    //     "command": "runCommands",
    //     "args": {
    //         "commands": [
    //             "workbench.action.chat.openInSidebar",
    //             "workbench.action.chat.focusInput"
    //         ]
    //     }
    // },
    {
        "key": "ctrl+alt+c",
        "command": "workbench.action.chat.openInEditor"
    },
    {
        "key": "[ c",
        "command": "notebook.focusPreviousEditor",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "[ shift+c",
        "command": "notebook.focusTop",
        "when": "notebookEditorFocused && !inputFocus"
    },
    {
        "key": "] c",
        "command": "notebook.focusNextEditor",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "] shift+c",
        "command": "notebook.focusBottom",
        "when": "notebookEditorFocused && !inputFocus"
    },
    // resize windows
    {
        "key": "alt+j",
        "command": "workbench.action.increaseViewSize",
        "when": "activeEditorGroupIndex != lastEditorGroupIndex"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.decreaseViewSize",
        "when": "activeEditorGroupIndex != 0"
    },
    {
        "key": "alt+j",
        "command": "workbench.action.terminal.resizePaneDown"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.terminal.resizePaneUp"
    },
    // Remove comamnds
    {
        "key": "ctrl+f",
        "command": "-workbench.action.terminal.focusFind",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },
    {
        "key": "ctrl+g",
        "command": "-workbench.action.terminal.goToRecentDirectory",
        "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported"
    },
    {
        "key": "ctrl+f",
        "command": "-actions.find",
        "when": "editorFocus || editorIsOpen"
    }
]