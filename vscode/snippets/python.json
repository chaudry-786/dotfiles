{
  // ----------DUCKDB----------
  "db": {
    "prefix": "db",
    "body": [
      "duckdb.query(\"\"\"",
      "\tSELECT ${2:*} FROM ${3:df}",
      "\"\"\")"
    ],
    "description": "Basic DuckDB SELECT * FROM"
  },
  "dbw": {
    "prefix": "dbw",
    "body": [
      "duckdb.query(\"\"\"",
      "\tSELECT ${2:*} FROM ${3:df}",
      "\tWHERE ${4:condition}",
      "\"\"\")"
    ],
    "description": "DuckDB SELECT with WHERE clause"
  },
  "dbg": {
    "prefix": "dbg",
    "body": [
      "duckdb.query(\"\"\"",
      "\tSELECT ${2:column}, COUNT(*)",
      "\tFROM ${3:df}",
      "\tGROUP BY ${2:column}",
      "\"\"\")"
    ],
    "description": "DuckDB GROUP BY"
  },
  "dbwg": {
    "prefix": "dbwg",
    "body": [
      "duckdb.query(\"\"\"",
      "\tSELECT ${2:column}, COUNT(*)",
      "\tFROM ${3:df}",
      "\tWHERE ${4:condition}",
      "\tGROUP BY ${2:column}",
      "\"\"\")"
    ],
    "description": "DuckDB WHERE and GROUP BY"
  },
  "dbwgh": {
    "prefix": "dbwgh",
    "body": [
      "duckdb.query(\"\"\"",
      "\tSELECT ${2:column}, COUNT(*)",
      "\tFROM ${3:df}",
      "\tWHERE ${4:condition}",
      "\tGROUP BY ${2:column}",
      "\tHAVING ${5:having_condition}",
      "\"\"\")"
    ],
    "description": "DuckDB SELECT with WHERE, GROUP BY, and HAVING"
  },
  // ----------END DUCKDB----------
