{
    // Refer to this link https://github.com/neoclide/coc.nvim/blob/master/data/schema.json
    // Diagnostic settings
    "diagnostic.level": "hint",
    "diagnostic.errorSign": "",
    "diagnostic.warningSign": "",
    "diagnostic.infoSign": "",
    "diagnostic.hintSign": "",
    "diagnostic.enableMessage": "jump",
    "diagnostic.virtualText": true,
    "diagnostic.virtualTextPrefix": "        ",

    // Snippets settings
    "snippets.extends": {
        "javascript": ["html", "javascriptreact"]
    },
    "snippets.snipmate.enable": false,
    "snippets.userSnippetsDirectory": "~/.config/nvim/snippets/",

    // Signature settings
    "signature.target": "float",
    "signature.floatConfig": {
        "maxHeight": 5,
        "border": true,
        "rounded": true
    },
    "signature.preferShownAbove": false,

    // SQL settings
    "sql.database": "bigquery",
    "sql.formatOptions": {
        "tabWidth": 4,
        // https://github.com/sql-formatter-org/sql-formatter/blob/master/docs/language.md
        "language": "bigquery"
    },

    // Python settings
    "python.formatting.provider": "black",
    "python.formatting.blackPath": "~/vim_venv/bin/black",
    "pyright.disableDiagnostics": true, // disable pyright linting
    "python.linting.enabled": true, // enable external linters
    "python.linting.pylintEnabled": true, // enable pylint
    "python.linting.pylintArgs": ["-d", "C0114,C0116,W0511,E1101,W1514,W0718"], // errors to ignore

    // Lua settings
    "sumneko-lua.enableNvimLuaDev": true,
    "sumneko-lua.checkUpdate": false,
    "Lua.window.statusBar": false,
    "Lua.hint.enable": false,
    "Lua.workspace.checkThirdParty": false,

    // HTML settings
    "htmldjango.djlint.profile": "jinja",
    "html-css-support.enabledLanguages": ["html", "htmldjango"],
    "html-css-support.styleSheets": [
        "https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.css",
        "/style.css",
        "style.css"
    ],

    // General settings
    "prettier.tabWidth": 4,
    "inlayHint.enable": false,

    // Hover settings
    "hover.floatConfig": {
        "border": true,
        "rounded": true
    },

    // Suggest settings
    "coc.source.around.enable": false,
    "suggest.noselect": true,
    "suggest.formatItems": ["abbr", "kind"],
    "suggest.floatConfig": {
        "border": true,
        "rounded": true
    },
    "suggest.completionItemKindLabels": {
        "class": "\uf0e8 Class",
        "color": " Color    ",
        "constant": " Constant ",
        "default": "\uf29c Default",
        "enum": " Enum     ",
        "enumMember": " EnumMember",
        "event": " Event    ",
        "field": " Field    ",
        "file": " File     ",
        "folder": " Folder   ",
        "function": " Function ",
        "interface": " Interface",
        "keyword": "󰌋 Keyword  ",
        "method": " Method   ",
        "module": " Module   ",
        "operator": "󱓉 Operator ",
        "property": " Property ",
        "reference": "󰈇 Reference",
        "snippet": " Snippet  ",
        "struct": " Struct   ",
        "text": "󰉿 Text     ",
        "typeParameter": "󰊄 TypeParameter",
        "unit": "󰑭 Unit     ",
        "value": "󰎠 Value    ",
        "variable": " Variable "
    }
}
