{
    // Refer to this link https://github.com/neoclide/coc.nvim/blob/master/data/schema.json
    "diagnostic.level": "hint",
    "diagnostic.errorSign": "",
    "diagnostic.warningSign": "",
    "diagnostic.infoSign": "",
    "diagnostic.hintSign": "",
    "diagnostic.enableMessage": "jump",
    "diagnostic.virtualText": true,
    "diagnostic.virtualTextPrefix": "        ",
    // snippets
    "snippets.extends": {
        "javascript": ["html", "javascriptreact"]
    },
    "snippets.snipmate.enable": false,
    "snippets.userSnippetsDirectory": "~/.config/nvim/snippets/",
    // doc shown when in insert mode, easily points what args are required
    "signature.target": "float",
    "signature.floatConfig": {
        "maxHeight": 5,
        "border": true,
        "rounded": true
    },
    // sql
    "sql.database": "bigquery",
    "sql.formatOptions": {
        "tabWidth": 4,
        // https://github.com/sql-formatter-org/sql-formatter/blob/master/docs/language.md
        "language": "bigquery"
    },
    // python
    "python.formatting.provider": "black",
    "python.formatting.blackPath": "~/vim_venv/bin/black",
    "pyright.disableDiagnostics": true,                     // disable pyright linting
    "python.linting.enabled": true,                         // enable external linters
    "python.linting.pylintEnabled": true,                   // enable pylint
    "python.linting.pylintArgs": ["-d", "C0114,C0116"],     // errors to ignore
    // Lua
    "sumneko-lua.enableNvimLuaDev": true,
    "sumneko-lua.checkUpdate": false,
    "Lua.telemetry.enable": false,
    "Lua.window.statusBar": false,
    "Lua.hint.enable": false,
    // general
    "prettier.tabWidth": 4,
    "inlayHint.enable": false,
    //suggest
    "coc.source.around.enable": false, // disables buffer, file and around completion
    "suggest.noselect": true,
    "suggest.formatItems": ["abbr", "kind"],
    "suggest.floatConfig": {
        "border": true,
        "rounded": true,
    },
    "suggest.completionItemKindLabels": {
        "class": "\uf0e8 Class",
        "color": " Color    ",
        "constant": " Constant ",
        "default": "\uf29c Default",
        "enum": " Enum     ",
        "enumMember": " EnumMember",
        "event": " Event    ",
        "field": " Field    ",
        "file": " File     ",
        "folder": " Folder   ",
        "function": " Function ",
        "interface": " Interface",
        "keyword": " Keyword  ",
        "method": " Method   ",
        "module": " Module   ",
        "operator": " Operator ",
        "property": " Property ",
        "reference": " Reference",
        "snippet": " Snippet  ",
        "struct": " Struct   ",
        "text": " Text     ",
        "typeParameter": " TypeParameter",
        "unit": "塞 Unit     ",
        "value": " Value    ",
        "variable": " Variable "
    }
}
